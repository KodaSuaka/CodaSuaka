<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.CodaSuaka" parent="android:Theme.Material.Light.NoActionBar" />

    <!-- Post-Splash Theme (Your App's main theme) -->
    <style name="Theme.App.Main" parent="Theme.CodaSuaka">
        <!-- Add your app's light theme attributes here -->
    </style>

    <!-- Splash Screen Theme -->
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <!-- Background of the splash screen -->
        <item name="windowSplashScreenBackground">@color/white</item>
        <!-- Icon that will be shown in the center -->
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash_icon</item>
        <!-- Theme to use after the splash screen is finished -->
        <item name="postSplashScreenTheme">@style/Theme.App.Main</item>
    </style>
</resources>
